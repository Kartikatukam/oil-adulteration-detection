<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="#F5F5F5"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Scanning">

    <!-- Header -->

    <TextView
        android:id="@+id/scanningHeader"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:gravity="center"
        android:text="Scanning in Progress"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        app:layout_constraintTop_toTopOf="parent"/>


    <!-- Status Text -->

    <LinearLayout
        android:id="@+id/textScanning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/scanningHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyzing Spectrum..."
            android:textSize="16sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Collecting Sample Data..."
            android:textSize="16sp"/>

    </LinearLayout>


    <!-- Circular Progress -->

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/circularProgress"
        android:layout_width="200dp"
        android:layout_height="200dp"
        app:indicatorSize="200dp"
        app:indicatorColor="#4CAF50"
        app:trackColor="#E0E0E0"
        app:trackThickness="12dp"
        app:layout_constraintTop_toBottomOf="@id/textScanning"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="30dp"/>


    <!-- Time Remaining -->

    <TextView
        android:id="@+id/timeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time Remaining &lt; 2 minutes"
        android:textSize="12sp"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/circularProgress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- Cancel Button -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/cancelButton"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="Cancel"
        android:textColor="#FF0000"
        android:layout_marginTop="40dp"
        android:backgroundTint="@android:color/transparent"
        app:strokeColor="#FF0000"
        app:strokeWidth="1dp"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/timeText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>